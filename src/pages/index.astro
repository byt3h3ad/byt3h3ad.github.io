---
import Layout from "../layouts/Layout.astro";
import Social from "../components/Social.astro";
import RecentTracks from "../components/RecentTracks.astro";

const handles = [
  {
    uri: "https://x.com/byt3h3ad",
    label: "\u0058",
  },
  {
    uri: "https://www.linkedin.com/in/byt3h3ad",
    label: "LinkedIn",
  },
  {
    uri: "https://github.com/byt3h3ad",
    label: "GitHub",
  },
  {
    uri: "https://read.cv/adhiraj",
    label: "About",
  },
  {
    uri: "/read",
    label: "Read",
  },
];
---

<Layout title="Adhiraj">
  <main>
    <div class="flex h-screen md:flex-row">
      <div class="m-auto text-center p-2 flex-1">
        <div class="inline-block">
          <h1 id="name">Adhiraj Dutta</h1>
          <h2 id="title">nerd, student, dev</h2>
        </div>
        <div class="h-6"></div>
        <ul class="text-center flex justify-center">
          {
            handles.map(({ uri, label }, idx) => (
              <li>
                <Social platform={uri} username={label} key={idx} />
              </li>
            ))
          }
        </ul>
      </div>
      <div class="m-auto text-center p-4 flex-1">
        <p class="text-slate-900">
          Technologist interested in making and breaking stuff. Insanely
          curious. Checkout my resume <a
            href="/resume"
            target="_blank"
            rel="noreffer"
            class="text-zinc-900">here</a
          >.
        </p>
        <span class="">
          <RecentTracks />
        </span>
      </div>
    </div>
  </main>
</Layout>

<style>
  html,
  body {
    @apply text-white;
    background-color: #000000;
  }

  #name,
  #title {
    letter-spacing: -0.06em;
  }

  #name {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
    user-select: none;
  }

  #title {
    @apply text-2xl;
    font-weight: 600;
  }

  a:hover {
    color: #0000ff;
  }

  li {
    list-style: none;
    @apply px-2;
    border-right: 1px solid whitesmoke;
  }

  li:last-child {
    border-right: none;
  }

  /* https://github.com/kiding/wanna-see-a-whiter-white */

  /* WebKit */
  @supports (-webkit-backdrop-filter: blur(0)) {
    h1,
    h2,
    p {
      filter: brightness(10);
      -webkit-backdrop-filter: brightness(1);
    }
  }

  /* Blink */
  @supports (backdrop-filter: blur(0)) {
    h1,
    h2,
    p {
      filter: brightness(10);
      backdrop-filter: brightness(1);
    }
  }
</style>
